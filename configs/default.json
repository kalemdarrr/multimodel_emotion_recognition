{
  "experiment_name": "english_multimodal_emotion",
  "model": {
    "labels": [
      "neutral",
      "joy",
      "sadness",
      "anger",
      "fear",
      "disgust",
      "surprise"
    ],
    "text_model_name": "bert-base-uncased",
    "text_backbone": "bert",
    "audio_feature_dim": 768,
    "video_feature_dim": 1280,
    "projection_dim": 256,
    "fusion_hidden_dim": 512,
    "dropout": 0.2,
    "modality_dropout": 0.1,
    "max_text_length": 128,
    "freeze_text_encoder": false,
    "load_pretrained_text_encoder": true
  },
  "training": {
    "epochs": 10,
    "batch_size": 8,
    "learning_rate": 2e-05,
    "weight_decay": 0.01,
    "gradient_clip_norm": 1.0,
    "early_stopping_patience": 3,
    "seed": 42,
    "device": "auto",
    "num_workers": 0
  }
}
